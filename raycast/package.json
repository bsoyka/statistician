{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "statistician",
  "title": "Statistician",
  "description": "Personal statistic management",
  "icon": "extension-icon.png",
  "author": "bsoyka",
  "owner": "bsoyka-org",
  "platforms": [
    "Windows",
    "macOS"
  ],
  "categories": [
    "Data"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "get-all-stats",
      "title": "Get All Stats",
      "subtitle": "Statistician",
      "description": "Browse all stats",
      "mode": "view"
    },
    {
      "name": "create-stat",
      "title": "Create Stat",
      "subtitle": "Statistician",
      "description": "Create a new stat",
      "mode": "view"
    },
    {
      "name": "update-stat",
      "title": "Update Stat",
      "subtitle": "Statistician",
      "description": "Update a stat by key",
      "mode": "view",
      "arguments": [
        {
          "name": "stat_key",
          "placeholder": "Stat key",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "name": "log-volunteer-entry",
      "title": "Log Volunteer Entry",
      "subtitle": "Statistician",
      "description": "Log a new volunteer time entry",
      "mode": "view"
    },
    {
      "name": "log-ctl-week",
      "title": "Log CTL Week",
      "subtitle": "Statistician",
      "description": "Log or update a CTL training week",
      "mode": "view"
    },
    {
      "name": "view-volunteer-entries",
      "title": "View Volunteer Entries",
      "subtitle": "Statistician",
      "description": "Browse volunteer time entries",
      "mode": "view"
    }
  ],
  "tools": [],
  "preferences": [
    {
      "name": "apiUrl",
      "title": "API URL",
      "description": "Base URL of the Statistician API",
      "type": "textfield",
      "required": true
    },
    {
      "name": "apiKey",
      "title": "API Key",
      "description": "API key JSON from the generate script",
      "type": "password",
      "required": true
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.20",
    "@raycast/utils": "^2.2.7"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.2.0",
    "@types/node": "22.19.17",
    "@types/react": "19.0.10",
    "eslint": "^10.5.0",
    "prettier": "^3.8.5",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo \"\\n\\nIt seems like you are trying to publish the Raycast extension to npm.\\n\\nIf you did intend to publish it to npm, remove the \\`prepublishOnly\\` script and rerun \\`npm publish\\` again.\\nIf you wanted to publish it to the Raycast Store instead, use \\`npm run publish\\` instead.\\n\\n\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  }
}
